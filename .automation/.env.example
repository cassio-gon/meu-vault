# Firecrawl API key (https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-...

# Groq API key (console.groq.com) — usada pelo modo digest (free tier)
GROQ_API_KEY=gsk_...

# Caminho raiz do seu vault (Obsidian, etc.)
VAULT_PATH=/home/cassio/vault

# Repositório GitHub do vault (usado apenas como referência/documentação)
GITHUB_REPO=git@github.com:cassio/vault.git

# Tag padrão aplicada quando --tag não é informado
DEFAULT_TAG=research

# Subpasta dentro do vault onde as notas são salvas (relativa a VAULT_PATH)
NOTES_SUBDIR=Research

# Branch usada no push
GIT_BRANCH=main
